<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
    http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">
    
    <!-- Setter Injection -->
    <bean id = "employee1" class="com.coforge.model.Employee">
        <property name="empid" value="1010"></property>
        <property name="empname" value="Abhi"></property>
        <property name="email" value="abhi@mail.com"></property>
        <property name="salary" value="10101"></property>
        <property name="dno" value="10"></property>
        <property name = "address" ref="address1"></property>
        <property name = "project" ref = "project2"></property>
    </bean> 
    
    <!--  Constructor Injection (Recommended) -->
     <bean id = "employee2" class="com.coforge.model.Employee">
        <constructor-arg name="empid" value="1020"></constructor-arg>
        <constructor-arg name="empname" value="Sai"></constructor-arg>
        <constructor-arg name="email" value="sai@mail.com"></constructor-arg>
        <constructor-arg name="salary" value="10101"></constructor-arg>
        <constructor-arg name="dno" value="10"></constructor-arg>
        <constructor-arg name = "address" ref="address2"></constructor-arg>
        <constructor-arg name = "project" ref = "project1"></constructor-arg>
    </bean>
    
    <bean id = "myInt" class="java.lang.Integer">
      <constructor-arg index="0" value="10"></constructor-arg>
    </bean>
    
    <bean id = "address1" class = "com.coforge.model.Address">
    <property name="city" value = "city1"></property>
    <property name="state" value = "state1"></property>
    </bean>
    
    <bean id = "address2" class = "com.coforge.model.Address">
    <property name="city" value = "city2"></property>
    <property name="state" value = "state2"></property>
    </bean>
    
    <bean id = "project1" class = "com.coforge.model.Project">
    <constructor-arg name = "pid" value = "1"></constructor-arg>
    <constructor-arg name = "pname" value = "project-one"></constructor-arg>
    </bean>
    
    <bean id = "project2" class = "com.coforge.model.Project">
    <property name = "pid" value = "2"></property>
    <property name = "pname" value = "project-two"></property>
    </bean>
</beans>